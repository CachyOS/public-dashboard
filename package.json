{
    "name": "public-dashboard",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "dotenv -e .env.local -- vite dev --port 3000",
        "build": "vite build && bun run scripts/prefill-cache.ts",
        "preview": "vite preview",
        "start": "bun server.mjs",
        "test": "bun test",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check && eslint && tsc --noEmit"
    },
    "dependencies": {
        "@fontsource-variable/inter": "^5.2.0",
        "@fontsource-variable/jetbrains-mono": "^5.2.0",
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-query": "latest",
        "@tanstack/react-query-devtools": "latest",
        "@tanstack/react-router": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/react-router-ssr-query": "latest",
        "@tanstack/react-start": "latest",
        "@tanstack/react-table": "^8.21.3",
        "@tanstack/router-plugin": "^1.132.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dotenv-cli": "^11.0.0",
        "ioredis": "^5.10.1",
        "lucide-react": "^0.545.0",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.1.18",
        "tw-animate-css": "^1.4.0",
        "usehooks-ts": "^3.1.1",
        "zod": "^4.3.6"
