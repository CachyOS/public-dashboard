        "@tanstack/devtools-vite": "latest",
        "@tanstack/eslint-plugin-query": "^5.99.1",
        "@types/bun": "^1.3.12",
        "@types/node": "^22.10.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "dotenv": "^17.3.1",
        "eslint": "=9",
        "tsx": "^4.21.0",
        "typescript": "^5.7.2",
        "vite": "^8.0.0"
